# Canonical Nebula self-hosted deployment profile.

# Application
NEBULA_APP_NAME=Nebula
NEBULA_ENV=production
NEBULA_RUNTIME_PROFILE=premium_first
NEBULA_API_V1_PREFIX=/v1
NEBULA_DEFAULT_MODEL=nebula-auto
NEBULA_LOG_LEVEL=INFO
NEBULA_ENABLE_METRICS=true

# Premium-first runtime
NEBULA_DATABASE_URL=postgresql+psycopg://nebula:nebula@postgres:5432/nebula
NEBULA_PREMIUM_PROVIDER=openai_compatible
NEBULA_PREMIUM_BASE_URL=https://openrouter.ai/api/v1
NEBULA_PREMIUM_API_KEY=replace-with-real-premium-api-key
NEBULA_PREMIUM_MODEL=openai/gpt-4o-mini

# Cache and optional local optimization
NEBULA_QDRANT_URL=http://qdrant:6333
NEBULA_OLLAMA_BASE_URL=http://host.docker.internal:11434
NEBULA_LOCAL_MODEL=llama3.2:3b
NEBULA_EMBEDDING_MODEL=nomic-embed-text
NEBULA_EMBEDDING_DIMENSIONS=768
NEBULA_SEMANTIC_CACHE_COLLECTION=nebula-semantic-cache
NEBULA_SEMANTIC_CACHE_THRESHOLD=0.90

# Governance bootstrap access
NEBULA_ADMIN_API_KEY=replace-with-long-admin-key
NEBULA_BOOTSTRAP_TENANT_ID=default
NEBULA_BOOTSTRAP_TENANT_NAME=Default Workspace
NEBULA_BOOTSTRAP_API_KEY_NAME=default-workspace-key
NEBULA_BOOTSTRAP_API_KEY=replace-with-bootstrap-api-key
